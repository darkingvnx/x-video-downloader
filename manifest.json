{
  "manifest_version": 3,
  "name": "X (Twitter) Video Downloader Pro",
  "version": "2.0",
  "description": "Tải video X bằng API trực tiếp, hỗ trợ IDM.",
  "permissions": [],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://api.vxtwitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}